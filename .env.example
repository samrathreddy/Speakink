# SpeakInk Environment Variables
# Copy this file to .env and fill in your keys

# HuggingFace (for faster model downloads)
HF_TOKEN=

# Gemini (for AI text correction)
GEMINI_API_KEY=

# Cloud STT providers (optional, only if you want cloud STT)
ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=

# Ollama (local correction, only if using Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
